<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MGG.Pulse.UI.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:MGG.Pulse.UI.Converters"
    Background="{ThemeResource BackgroundBrush}">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24" Spacing="16">

            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Ellipse
                    Width="12"
                    Height="12"
                    Fill="{x:Bind ViewModel.StatusIndicatorBrush, Mode=OneWay}" />
                <TextBlock
                    Foreground="{ThemeResource TextPrimaryBrush}"
                    FontSize="20"
                    FontWeight="Bold"
                    Text="Dashboard" />
            </StackPanel>

            <Border Style="{StaticResource CardStyle}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="0"
                        FontSize="11"
                        Foreground="{ThemeResource TextSecondaryBrush}"
                        Text="Estado" />
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="0"
                        Margin="0,2,0,12"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource PrimaryBrush}"
                        Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />

                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="1"
                        FontSize="11"
                        Foreground="{ThemeResource TextSecondaryBrush}"
                        Text="Tiempo inactivo" />
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="1"
                        Margin="0,2,0,12"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextPrimaryBrush}"
                        Text="{x:Bind ViewModel.IdleTimeText, Mode=OneWay}" />

                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="0"
                        FontSize="11"
                        Foreground="{ThemeResource TextSecondaryBrush}"
                        Text="Última acción" />
                    <TextBlock
                        Grid.Row="3"
                        Grid.Column="0"
                        Margin="0,2,0,0"
                        FontSize="13"
                        Foreground="{ThemeResource TextPrimaryBrush}"
                        Text="{x:Bind ViewModel.LastActionText, Mode=OneWay}" />

                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="1"
                        FontSize="11"
                        Foreground="{ThemeResource TextSecondaryBrush}"
                        Text="Próxima acción" />
                    <TextBlock
                        Grid.Row="3"
                        Grid.Column="1"
                        Margin="0,2,0,0"
                        FontSize="13"
                        Foreground="{ThemeResource TextPrimaryBrush}"
                        Text="{x:Bind ViewModel.NextScheduledText, Mode=OneWay}" />
                </Grid>
            </Border>

            <Button
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.StartCommand, Mode=OneWay}"
                Content="Iniciar"
                Style="{StaticResource PrimaryButtonStyle}"
                Visibility="{x:Bind ViewModel.IsNotRunning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

            <Button
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.StopCommand, Mode=OneWay}"
                Content="Detener"
                Style="{StaticResource SecondaryButtonStyle}"
                Visibility="{x:Bind ViewModel.IsRunning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

        </StackPanel>
    </ScrollViewer>
</Page>
