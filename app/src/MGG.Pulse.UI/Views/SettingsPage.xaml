<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MGG.Pulse.UI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24" Spacing="16">

            <TextBlock
                Foreground="{StaticResource TextPrimaryBrush}"
                FontSize="20"
                FontWeight="Bold"
                Text="Settings" />

            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock
                        Foreground="{StaticResource TextPrimaryBrush}"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Text="Configuration" />

                    <StackPanel Spacing="6">
                        <TextBlock
                            Foreground="{StaticResource TextSecondaryBrush}"
                            FontSize="11"
                            Text="Mode" />
                        <ComboBox
                            HorizontalAlignment="Stretch"
                            SelectedValue="{x:Bind ViewModel.SelectedMode, Mode=TwoWay}"
                            SelectedValuePath="Content">
                            <ComboBoxItem Content="Intelligent" />
                            <ComboBoxItem Content="Aggressive" />
                            <ComboBoxItem Content="Manual" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock
                            Foreground="{StaticResource TextSecondaryBrush}"
                            FontSize="11"
                            Text="Input Type" />
                        <ComboBox
                            HorizontalAlignment="Stretch"
                            SelectedValue="{x:Bind ViewModel.SelectedInputType, Mode=TwoWay}"
                            SelectedValuePath="Content">
                            <ComboBoxItem Content="Mouse" />
                            <ComboBoxItem Content="Keyboard" />
                            <ComboBoxItem Content="Combined" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock
                            Foreground="{StaticResource TextSecondaryBrush}"
                            FontSize="11"
                            Text="Interval (seconds)" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <NumberBox
                                Grid.Column="0"
                                Maximum="3600"
                                Minimum="1"
                                PlaceholderText="Min"
                                SpinButtonPlacementMode="Hidden"
                                Value="{x:Bind ViewModel.IntervalMin, Mode=TwoWay}" />
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="&#x2014;" />
                            <NumberBox
                                Grid.Column="2"
                                Maximum="3600"
                                Minimum="1"
                                PlaceholderText="Max"
                                SpinButtonPlacementMode="Hidden"
                                Value="{x:Bind ViewModel.IntervalMax, Mode=TwoWay}" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock
                        Foreground="{StaticResource TextPrimaryBrush}"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Text="Stealth Options" />

                    <ToggleSwitch
                        Header="Start with Windows"
                        IsOn="{x:Bind ViewModel.StartWithWindows, Mode=TwoWay}"
                        OffContent="Disabled"
                        OnContent="Enabled" />
                    <ToggleSwitch
                        Header="Start Minimized"
                        IsOn="{x:Bind ViewModel.StartMinimized, Mode=TwoWay}"
                        OffContent="Disabled"
                        OnContent="Enabled" />
                    <ToggleSwitch
                        Header="Minimize to Tray"
                        IsOn="{x:Bind ViewModel.MinimizeToTray, Mode=TwoWay}"
                        OffContent="Disabled"
                        OnContent="Enabled" />
                </StackPanel>
            </Border>

            <Button
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.SaveCommand, Mode=OneWay}"
                Content="Save Settings"
                Style="{StaticResource PrimaryButtonStyle}" />

            <TextBlock
                HorizontalAlignment="Center"
                Foreground="{StaticResource PrimaryBrush}"
                FontSize="12"
                Text="{x:Bind ViewModel.SaveStatusMessage, Mode=OneWay}" />
        </StackPanel>
    </ScrollViewer>
</Page>
