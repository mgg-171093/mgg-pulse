<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MGG.Pulse.UI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24" Spacing="16">

            <TextBlock
                Foreground="{ThemeResource TextPrimaryBrush}"
                FontSize="20"
                FontWeight="Bold"
                Text="Configuración" />

            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock
                        Foreground="{ThemeResource TextPrimaryBrush}"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Text="Comportamiento de simulación" />

                    <StackPanel Spacing="6">
                        <TextBlock
                            Foreground="{ThemeResource TextSecondaryBrush}"
                            FontSize="11"
                            Text="Modo" />
                        <ComboBox
                            HorizontalAlignment="Stretch"
                            SelectedValue="{x:Bind ViewModel.SelectedMode, Mode=TwoWay}"
                            SelectedValuePath="Tag">
                            <ComboBoxItem Content="Inteligente" Tag="Intelligent" />
                            <ComboBoxItem Content="Agresivo" Tag="Aggressive" />
                            <ComboBoxItem Content="Manual" Tag="Manual" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock
                            Foreground="{ThemeResource TextSecondaryBrush}"
                            FontSize="11"
                            Text="Tipo de entrada" />
                        <ComboBox
                            HorizontalAlignment="Stretch"
                            SelectedValue="{x:Bind ViewModel.SelectedInputType, Mode=TwoWay}"
                            SelectedValuePath="Tag">
                            <ComboBoxItem Content="Ratón" Tag="Mouse" />
                            <ComboBoxItem Content="Teclado" Tag="Keyboard" />
                            <ComboBoxItem Content="Combinado" Tag="Combined" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock
                            Foreground="{ThemeResource TextSecondaryBrush}"
                            FontSize="11"
                            Text="Intervalo (segundos)" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <NumberBox
                                Grid.Column="0"
                                Maximum="3600"
                                Minimum="1"
                                PlaceholderText="Mín"
                                SpinButtonPlacementMode="Hidden"
                                Value="{x:Bind ViewModel.IntervalMin, Mode=TwoWay}" />
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextSecondaryBrush}"
                                Text="&#x2014;" />
                            <NumberBox
                                Grid.Column="2"
                                Maximum="3600"
                                Minimum="1"
                                PlaceholderText="Máx"
                                SpinButtonPlacementMode="Hidden"
                                Value="{x:Bind ViewModel.IntervalMax, Mode=TwoWay}" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock
                        Foreground="{ThemeResource TextPrimaryBrush}"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Text="Opciones de sigilo" />

                    <ToggleSwitch
                        Header="Iniciar con Windows"
                        IsOn="{x:Bind ViewModel.StartWithWindows, Mode=TwoWay}"
                        OffContent="Desactivado"
                        OnContent="Activado" />
                    <ToggleSwitch
                        Header="Iniciar minimizado"
                        IsOn="{x:Bind ViewModel.StartMinimized, Mode=TwoWay}"
                        OffContent="Desactivado"
                        OnContent="Activado" />
                    <ToggleSwitch
                        Header="Minimizar a la bandeja"
                        IsOn="{x:Bind ViewModel.MinimizeToTray, Mode=TwoWay}"
                        OffContent="Desactivado"
                        OnContent="Activado" />
                </StackPanel>
            </Border>

            <Button
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.SaveCommand, Mode=OneWay}"
                Content="Guardar configuración"
                Style="{StaticResource PrimaryButtonStyle}" />

            <TextBlock
                HorizontalAlignment="Center"
                Foreground="{ThemeResource PrimaryBrush}"
                FontSize="12"
                Text="{x:Bind ViewModel.SaveStatusMessage, Mode=OneWay}" />
        </StackPanel>
    </ScrollViewer>
</Page>
