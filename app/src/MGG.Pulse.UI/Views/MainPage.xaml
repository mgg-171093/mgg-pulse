<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MGG.Pulse.UI.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:MGG.Pulse.UI.Converters"
    Background="{StaticResource BackgroundBrush}">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="24">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Ellipse Width="12" Height="12"
                         Fill="{x:Bind ViewModel.StatusIndicatorBrush, Mode=OneWay}"/>
                <TextBlock Text="MGG Pulse"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
            </StackPanel>

            <!-- Status Card -->
            <Border Style="{StaticResource CardStyle}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Status -->
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="Status"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"
                               Margin="0,2,0,12"/>

                    <!-- Idle Time -->
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               Text="Idle Time"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1"
                               Text="{x:Bind ViewModel.IdleTimeText, Mode=OneWay}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,2,0,12"/>

                    <!-- Last Action -->
                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="Last Action"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Row="3" Grid.Column="0"
                               Text="{x:Bind ViewModel.LastActionText, Mode=OneWay}"
                               FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,2,0,0"/>

                    <!-- Next Scheduled -->
                    <TextBlock Grid.Row="2" Grid.Column="1"
                               Text="Next Action"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1"
                               Text="{x:Bind ViewModel.NextScheduledText, Mode=OneWay}"
                               FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,2,0,0"/>
                </Grid>
            </Border>

            <!-- Start/Stop Button -->
            <Button x:Name="ToggleButton"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.StartCommand, Mode=OneWay}"
                    Content="Start"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Visibility="{x:Bind ViewModel.IsNotRunning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <Button HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.StopCommand, Mode=OneWay}"
                    Content="Stop"
                    Background="#CC3333"
                    Foreground="White"
                    CornerRadius="8"
                    Padding="24,10"
                    FontWeight="SemiBold"
                    Visibility="{x:Bind ViewModel.IsRunning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Configuration Card -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Configuration"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>

                    <!-- Mode -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="Mode"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <ComboBox SelectedValue="{x:Bind ViewModel.SelectedMode, Mode=TwoWay}"
                                  SelectedValuePath="Content"
                                  HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Intelligent"/>
                            <ComboBoxItem Content="Aggressive"/>
                            <ComboBoxItem Content="Manual"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Input Type -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="Input Type"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <ComboBox SelectedValue="{x:Bind ViewModel.SelectedInputType, Mode=TwoWay}"
                                  SelectedValuePath="Content"
                                  HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Mouse"/>
                            <ComboBoxItem Content="Keyboard"/>
                            <ComboBoxItem Content="Combined"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Interval -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="Interval (seconds)"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <NumberBox Grid.Column="0"
                                       Value="{x:Bind ViewModel.IntervalMin, Mode=TwoWay}"
                                       Minimum="1" Maximum="3600"
                                       PlaceholderText="Min"
                                       SpinButtonPlacementMode="Hidden"/>
                            <TextBlock Grid.Column="1" Text="—"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <NumberBox Grid.Column="2"
                                       Value="{x:Bind ViewModel.IntervalMax, Mode=TwoWay}"
                                       Minimum="1" Maximum="3600"
                                       PlaceholderText="Max"
                                       SpinButtonPlacementMode="Hidden"/>
                        </Grid>
                    </StackPanel>

                    <Button Content="Save Configuration"
                            Command="{x:Bind ViewModel.SaveConfigCommand, Mode=OneWay}"
                            HorizontalAlignment="Stretch"
                            CornerRadius="8"
                            Background="{StaticResource SurfaceVariantBrush}"
                            Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Stealth Options -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Stealth Options"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>

                    <ToggleSwitch Header="Start with Windows"
                                  IsOn="{x:Bind ViewModel.StartWithWindows, Mode=TwoWay}"
                                  OnContent="Enabled" OffContent="Disabled"/>
                    <ToggleSwitch Header="Start Minimized"
                                  IsOn="{x:Bind ViewModel.StartMinimized, Mode=TwoWay}"
                                  OnContent="Enabled" OffContent="Disabled"/>
                    <ToggleSwitch Header="Minimize to Tray"
                                  IsOn="{x:Bind ViewModel.MinimizeToTray, Mode=TwoWay}"
                                  OnContent="Enabled" OffContent="Disabled"/>
                </StackPanel>
            </Border>

            <!-- Logs -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Activity Log"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <ScrollViewer Height="150" VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="{x:Bind ViewModel.LogText, Mode=OneWay}"
                                   FontFamily="Consolas"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
