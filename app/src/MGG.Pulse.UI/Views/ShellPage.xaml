<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MGG.Pulse.UI.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource BackgroundBrush}">

    <Grid Background="{ThemeResource SidebarSurfaceBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <NavigationView
            Grid.Row="0"
            x:Name="NavView"
            AlwaysShowHeader="True"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="True"
            PaneDisplayMode="Left"
            SelectionChanged="NavView_SelectionChanged">

            <NavigationView.PaneHeader>
                <Border
                    Margin="8"
                    Padding="8"
                    Background="{ThemeResource SurfaceVariantBrush}"
                    CornerRadius="8">
                    <Image
                        Width="170"
                        Height="52"
                        HorizontalAlignment="Left"
                        Source="ms-appx:///Assets/logo-sidebar.png"
                        Stretch="Uniform" />
                </Border>
            </NavigationView.PaneHeader>

            <NavigationView.MenuItems>
                <NavigationViewItem
                    Content="Panel"
                    Icon="Home"
                    GotFocus="NavItem_GotFocus"
                    LostFocus="NavItem_LostFocus"
                    PointerEntered="NavItem_PointerEntered"
                    PointerExited="NavItem_PointerExited"
                    Tag="Dashboard" />
                <NavigationViewItem
                    Content="Apariencia"
                    Icon="Highlight"
                    GotFocus="NavItem_GotFocus"
                    LostFocus="NavItem_LostFocus"
                    PointerEntered="NavItem_PointerEntered"
                    PointerExited="NavItem_PointerExited"
                    Tag="Appearance" />
                <NavigationViewItem
                    Content="Registros"
                    Icon="Document"
                    GotFocus="NavItem_GotFocus"
                    LostFocus="NavItem_LostFocus"
                    PointerEntered="NavItem_PointerEntered"
                    PointerExited="NavItem_PointerExited"
                    Tag="Logs" />
                <NavigationViewItem
                    Content="Acerca de"
                    Icon="Help"
                    GotFocus="NavItem_GotFocus"
                    LostFocus="NavItem_LostFocus"
                    PointerEntered="NavItem_PointerEntered"
                    PointerExited="NavItem_PointerExited"
                    Tag="About" />
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>

        <Border
            Grid.Row="1"
            Padding="12,8"
            Background="{ThemeResource SurfaceVariantBrush}"
            BorderBrush="{ThemeResource BorderBrush}"
            BorderThickness="1,1,0,0">
            <TextBlock
                Foreground="{ThemeResource TextSecondaryBrush}"
                FontSize="12"
                Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
        </Border>
    </Grid>
</Page>
