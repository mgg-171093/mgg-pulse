<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MGG.Pulse.UI.Views.AppearancePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24" Spacing="16">
            <TextBlock
                Foreground="{ThemeResource TextPrimaryBrush}"
                FontSize="20"
                FontWeight="Bold"
                Text="Apariencia" />

            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock
                        Foreground="{ThemeResource TextSecondaryBrush}"
                        FontSize="12"
                        Text="Preferencias de apariencia" />

                    <TextBlock
                        Foreground="{ThemeResource TextDisabledBrush}"
                        FontSize="11"
                        Text="El cambio de apariencia se aplicará al reiniciar la aplicación." />

                    <InfoBar
                        IsOpen="{x:Bind ViewModel.ShowRestartBanner, Mode=OneWay}"
                        IsClosable="False"
                        Message="El cambio de apariencia se aplicará al reiniciar la aplicación."
                        Severity="Informational">
                        <InfoBar.ActionButton>
                            <Button
                                Command="{x:Bind ViewModel.RestartCommand, Mode=OneWay}"
                                Content="Reiniciar"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        </InfoBar.ActionButton>
                    </InfoBar>

                    <StackPanel Spacing="8">
                        <RadioButton
                            Content="Oscuro"
                            GroupName="ThemeSelector"
                            IsChecked="{x:Bind ViewModel.IsDarkTheme, Mode=TwoWay}" />
                        <RadioButton
                            Content="Claro"
                            GroupName="ThemeSelector"
                            IsChecked="{x:Bind ViewModel.IsLightTheme, Mode=TwoWay}" />
                        <RadioButton
                            Content="Automático"
                            GroupName="ThemeSelector"
                            IsChecked="{x:Bind ViewModel.IsAutoTheme, Mode=TwoWay}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
