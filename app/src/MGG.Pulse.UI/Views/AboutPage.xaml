<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MGG.Pulse.UI.Views.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24" Spacing="24" HorizontalAlignment="Center" MaxWidth="480">

            <TextBlock
                Foreground="{ThemeResource TextPrimaryBrush}"
                FontSize="20"
                FontWeight="Bold"
                Text="Acerca de MGG Pulse" />

            <Border Style="{StaticResource CardStyle}">
                <StackPanel HorizontalAlignment="Center" Spacing="16">
                    <Image
                        Width="72"
                        Height="72"
                        HorizontalAlignment="Center"
                        Source="ms-appx:///Assets/logo.png" />

                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                        <TextBlock
                            Foreground="{ThemeResource TextPrimaryBrush}"
                            FontSize="22"
                            FontWeight="Bold"
                            HorizontalAlignment="Center"
                            Text="MGG Pulse" />
                        <TextBlock
                            Foreground="{ThemeResource TextSecondaryBrush}"
                            FontSize="13"
                            HorizontalAlignment="Center"
                            Text="Simulador de actividad" />
                    </StackPanel>

                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                        <TextBlock
                            Foreground="{ThemeResource TextSecondaryBrush}"
                            FontSize="11"
                            HorizontalAlignment="Center"
                            Text="Versión instalada" />
                        <TextBlock
                            Foreground="{ThemeResource PrimaryBrush}"
                            FontSize="15"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Center"
                            Text="{x:Bind ViewModel.InstalledVersion, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock
                        Foreground="{ThemeResource TextPrimaryBrush}"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Text="Actualizaciones" />

                    <Button
                        HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.CheckForUpdateCommand, Mode=OneWay}"
                        Content="Buscar actualizaciones"
                        Style="{StaticResource SecondaryButtonStyle}" />

                    <TextBlock
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextSecondaryBrush}"
                        FontSize="12"
                        Text="{x:Bind ViewModel.UpdateStatusMessage, Mode=OneWay}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <StackPanel HorizontalAlignment="Center" Spacing="4">
                <HyperlinkButton
                    HorizontalAlignment="Center"
                    Content="Ver cambios y lanzamientos"
                    FontSize="12"
                    NavigateUri="https://github.com/mgg-dev/mgg-pulse/releases" />
                <TextBlock
                    Foreground="{ThemeResource TextDisabledBrush}"
                    FontSize="11"
                    HorizontalAlignment="Center"
                    Text="&#xA9; 2024 MGG &#xB7; MIT License" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
