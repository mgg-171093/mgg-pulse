<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MGG.Pulse.UI.Windows.SplashWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Width="600" Height="750">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1A2336" Offset="0.0" />
                <GradientStop Color="#0F111A" Offset="0.6" />
                <GradientStop Color="#0A0D14" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="28">
            <Image
                x:Name="LogoImage"
                Width="400"
                Height="450"
                HorizontalAlignment="Center"
                Stretch="Uniform" />

            <ProgressBar
                x:Name="InitProgress"
                Width="260"
                Height="4"
                Minimum="0"
                Maximum="100"
                Value="0"
                Background="#2A2E45"
                Foreground="#4CAF50" />
        </StackPanel>
    </Grid>
</Window>
