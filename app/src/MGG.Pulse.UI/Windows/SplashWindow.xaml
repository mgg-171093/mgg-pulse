<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MGG.Pulse.UI.Windows.SplashWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#0F111A" Width="400" Height="280">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24">

            <!-- Logo with fade-in animation -->
            <Image x:Name="LogoImage"
                   Width="80" Height="80"
                   HorizontalAlignment="Center"
                   Opacity="0">
                <Image.RenderTransform>
                    <ScaleTransform x:Name="LogoScale" ScaleX="0.8" ScaleY="0.8"/>
                </Image.RenderTransform>
            </Image>

            <!-- App name -->
            <StackPanel HorizontalAlignment="Center" Spacing="4" Opacity="0" x:Name="TextPanel">
                <TextBlock Text="MGG Pulse"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Activity Simulator"
                           FontSize="12"
                           Foreground="#B0B3C0"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Progress bar -->
            <ProgressBar x:Name="InitProgress"
                         Width="240"
                         Height="3"
                         Minimum="0"
                         Maximum="100"
                         Value="0"
                         Foreground="#4CAF50"
                         Background="#2A2E45"/>

            <!-- Status text -->
            <TextBlock x:Name="StatusText"
                       Text="Initializing..."
                       FontSize="11"
                       Foreground="#6B6F80"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
