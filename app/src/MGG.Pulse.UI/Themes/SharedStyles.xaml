<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Shared interaction state layers -->
    <x:Double x:Key="StateLayerHoverOpacity">0.08</x:Double>
    <x:Double x:Key="StateLayerPressedOpacity">0.14</x:Double>
    <x:Double x:Key="StateLayerFocusOpacity">0.18</x:Double>

    <!-- Shared baseline corner radius -->
    <CornerRadius x:Key="SharedCornerRadius">8</CornerRadius>
    <Thickness x:Key="FocusRingThickness">1</Thickness>

    <!-- Cursor intent metadata for interactive controls.
         Runtime cursor usage is applied in interactive handlers with
         InputSystemCursor.Create(InputSystemCursorShape.Hand) targeting ProtectedCursor. -->
    <x:String x:Key="InteractiveCursorProperty">ProtectedCursor</x:String>
    <x:String x:Key="InteractiveCursorShape">InputSystemCursorShape.Hand</x:String>

    <Style x:Key="BaseButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="CornerRadius" Value="{StaticResource SharedCornerRadius}"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}"/>
        <Setter Property="Background" Value="{ThemeResource SurfaceRaisedBrush}"/>
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="{ThemeResource PrimaryBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="{ThemeResource SurfaceVariantBrush}"/>
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}"/>
    </Style>

    <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
        <Setter Property="Width" Value="40"/>
        <Setter Property="MinWidth" Value="40"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="BaseCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource SurfaceRaisedBrush}"/>
        <Setter Property="CornerRadius" Value="{StaticResource SharedCornerRadius}"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="CardStyle" TargetType="Border" BasedOn="{StaticResource BaseCardStyle}">
        <Setter Property="Background" Value="{ThemeResource SurfaceBrush}"/>
    </Style>

    <Style x:Key="FocusedCardStyle" TargetType="Border" BasedOn="{StaticResource BaseCardStyle}">
        <Setter Property="BorderBrush" Value="{ThemeResource FocusRingBrush}"/>
        <Setter Property="BorderThickness" Value="{StaticResource FocusRingThickness}"/>
    </Style>
</ResourceDictionary>
