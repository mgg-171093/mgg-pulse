# ── Generated / temp ─────────────────────────────────────────
*.tmp
*.temp
*.bak
*.swp
*~
.sass-cache/
app/build_diag.log
app/build_diag.binlog
app/build/output/
app/build/publish/
app/src/MGG.Pulse.UI/xaml_err.txt
app/src/MGG.Pulse.UI/xaml_out.txt
app/src/MGG.Pulse.UI/build_log.txt
app/src/MGG.Pulse.UI/logs.json
