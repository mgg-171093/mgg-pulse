out.log

# ── Secrets / environment ─────────────────────────────────────
*.env
*.env.*
!*.env.example
secrets.json
appsettings.local.json
appsettings.*.local.json

# ── Local app data (NOT committed) ───────────────────────────
# Config lives at %AppData%\MGG\Pulse\config.json — never in repo

# Keep source folder named Win32 under Infrastructure
!app/src/MGG.Pulse.Infrastructure/Win32/
!app/src/MGG.Pulse.Infrastructure/Win32/*.cs
